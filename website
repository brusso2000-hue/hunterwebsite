  const [productFilter, setProductFilter] = useState("All");
  const [cartOpen, setCartOpen] = useState(false);
  const [orderDone, setOrderDone] = useState(false);
  const cart = useCart();

  const handleNav = (p, filter) => {
    setPage(p);
    if (filter) setProductFilter(filter);
    else if (p === "products") setProductFilter("All");
    window.scrollTo({ top: 0, behavior: "smooth" });
    setCartOpen(false);
  };

  const handleCheckout = () => {
    setCartOpen(false);
    setPage("checkout");
    window.scrollTo({ top: 0 });
  };

  const handleOrderSuccess = () => {
    setPage("order-confirm");
    window.scrollTo({ top: 0 });
  };

  return (
    <>
      <style>{CSS}</style>
      <Nav page={page} onNav={handleNav} cart={cart} onCartOpen={() => setCartOpen(true)} />
      <CartPanel cart={cart} open={cartOpen} onClose={() => setCartOpen(false)} onCheckout={handleCheckout} />

      <main>
        {page === "home" && <HomePage onNav={handleNav} cart={cart} />}
        {page === "products" && <ProductsPage cart={cart} filterInit={productFilter} onNav={handleNav} />}
        {page === "about" && <AboutPage />}
        {page === "applications" && <ApplicationsPage />}
        {page === "contact" && <ContactPage />}
        {page === "checkout" && <CheckoutPage cart={cart} onSuccess={handleOrderSuccess} />}
        {page === "order-confirm" && <OrderConfirmPage onNav={handleNav} />}
      </main>

      {page !== "checkout" && page !== "order-confirm" && <Footer onNav={handleNav} />}
    </>
  );
}
